rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function inBond(bondId) {
      return signedIn()
        && exists(/databases/$(database)/documents/bonds/$(bondId))
        && (
          get(/databases/$(database)/documents/bonds/$(bondId)).data.partnerAId == request.auth.uid
          || get(/databases/$(database)/documents/bonds/$(bondId)).data.partnerBId == request.auth.uid
        );
    }

    match /bonds/{bondId} {
      allow read: if inBond(bondId);
      allow create: if signedIn();
      allow update: if inBond(bondId)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['partnerAId', 'keyFingerprint']);

      match /{collection}/{docId} {
        allow read, write: if inBond(bondId)
          && collection in [
            'vows', 'memories', 'linkPulses', 'cherishEvents',
            'vault', 'dreams', 'bodyMap', 'presence', 'oracleMeta', 'metrics'
          ];
      }
    }

    match /partners/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if signedIn() && request.auth.uid == uid;
    }

    match /invites/{code} {
      allow read: if signedIn();
      allow write: if false; // Cloud Functions only
    }

    match /_rateLimits/{id} {
      allow read, write: if false;
    }
  }
}
