rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function inBondPath() {
      return request.auth != null
        && request.auth.uid != null;
    }

    // Encrypted blobs only — clients must upload ciphertext.
    match /bonds/{bondId}/{allPaths=**} {
      allow read, write: if inBondPath()
        && request.resource.size < 55 * 1024 * 1024
        && (
          request.resource == null
          || request.resource.contentType.matches('application/octet-stream|audio/.*|image/.*|video/.*')
        );
    }
  }
}
